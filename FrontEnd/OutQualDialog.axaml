<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ImagePrepSharp.FrontEnd.OutQualDialog"
        Title="Specify Output Quality"
        Width="400" Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">
    <Grid RowDefinitions="*,Auto,Auto" Margin="20">
        <TextBlock Grid.Row="0" TextWrapping="Wrap" VerticalAlignment="Center">Specify the output quality.</TextBlock>
        <NumericUpDown x:Name="OutQualSpinner" Minimum="1" Maximum="100" />
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="Cancel_Click" />
            <Button Content="OK" Click="OK_Click" />
        </StackPanel>
    </Grid>
</Window>
