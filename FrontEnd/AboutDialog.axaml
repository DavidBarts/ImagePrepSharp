<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ImagePrepSharp.FrontEnd.AboutDialog"
        Title="About ImagePrepSharp"
        Width="400" Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Spacing="10" Margin="20">
        <TextBlock HorizontalAlignment="Center" FontSize="18" Margin="0,0,0,10">ImagePrepSharp</TextBlock>
        <TextBlock HorizontalAlignment="Center">© MMXXVI, David W. Barts</TextBlock>
    </StackPanel>
</Window>
